# Hackathon stack template — copy to .env and fill in values
# See HACKATHON_SETUP.md for full instructions

LYZR_BASE_URL=https://agent-prod.studio.lyzr.ai

ORCHESTRATOR_AGENT_PROVIDER=lyzr
ORCHESTRATOR_AGENT_API_KEY=your-lyzr-api-key
ORCHESTRATOR_AGENT_LYZR_ID=your-orchestrator-agent-id
ORCHESTRATOR_AGENT_MODEL=gpt-4o-mini
ORCHESTRATOR_AGENT_TEMPERATURE=0.2
ORCHESTRATOR_AGENT_STREAMING=true

TUTOR_AGENT_PROVIDER=lyzr
TUTOR_AGENT_LYZR_ID=your-tutor-agent-id

LECTURE_AGENT_PROVIDER=lyzr
LECTURE_AGENT_LYZR_ID=your-lecture-agent-id

NOTES_AGENT_PROVIDER=lyzr
NOTES_AGENT_LYZR_ID=your-notes-agent-id

QUIZ_AGENT_PROVIDER=lyzr
QUIZ_AGENT_LYZR_ID=your-quiz-agent-id

FLASHCARD_AGENT_PROVIDER=lyzr
FLASHCARD_AGENT_LYZR_ID=your-flashcard-agent-id

ANALYTICS_AGENT_PROVIDER=lyzr
ANALYTICS_AGENT_LYZR_ID=your-analytics-agent-id

KNOWLEDGE_GRAPH_AGENT_PROVIDER=lyzr
KNOWLEDGE_GRAPH_AGENT_LYZR_ID=your-knowledge-graph-agent-id

OMI_DEEPGRAM_API_KEY=your-deepgram-key
OMI_UID=
VOICE_PROVIDER=omi

QDRANT_URL=http://localhost:6333
MEMORY_PROVIDER=qdrant

DATABASE_URL=sqlite:///./neurolearn.db
HOST=0.0.0.0
PORT=8000
AGENT_PORT=8001
